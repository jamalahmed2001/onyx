# ONYX — environment variables
# Copy to .env and fill in your values.
# .env is never committed to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Obsidian vault root (absolute path)
ONYX_VAULT_ROOT=/Users/you/vault

# OpenRouter API key — used for planning/atomiser LLM calls
# Get one at https://openrouter.ai — supports any model
OPENROUTER_API_KEY=sk-or-...

# ── Agent driver API keys (only needed if NOT using session login) ─────────────

# Claude Code: if you ran `claude login`, no key needed — session auth is used automatically.
# Only set this if running without a login session (e.g. CI/CD or fresh machine with no login).
# ANTHROPIC_API_KEY=sk-ant-...

# Cursor: if you are logged in to Cursor, no key needed.
# The agent CLI uses your existing Cursor session automatically.

# ── Optional ──────────────────────────────────────────────────────────────────

# Override the default model (default: anthropic/claude-sonnet-4-6)
# ONYX_MODEL=anthropic/claude-opus-4-6

# Linear integration (for onyx import)
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=TEAM_ID

# OpenClaw notifications (Master Directive §15)
# Requires the openclaw CLI installed + logged in.
# Set the recipient (E.164 phone number) — auto-routes to WhatsApp/Signal/etc.
# OPENCLAW_NOTIFY_TARGET=+447700900000
# (Or set in onyx.config.json: "notify": { "openclaw": { "target": "+44..." } })

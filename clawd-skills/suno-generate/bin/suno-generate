#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
SKILL_DIR="$(dirname "$SCRIPT_DIR")"
if [[ -f "$SKILL_DIR/dist/cli.js" ]]; then
  exec node --no-warnings "$SKILL_DIR/dist/cli.js" "$@"
else
  exec node --no-warnings --loader ts-node/esm "$SKILL_DIR/src/cli.ts" "$@"
fi
